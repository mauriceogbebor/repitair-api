# Server
PORT=4000
NODE_ENV=development

# Public URL — REQUIRED when testing on physical devices or deploying.
# Set to your machine's LAN IP (e.g. http://192.168.1.42:4000) for device testing,
# or your production domain for deployment. Without this, uploaded file URLs
# will point to http://localhost:4000 which is unreachable from devices.
# PUBLIC_URL=http://192.168.1.42:4000

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
# DATABASE_URL=postgresql://repitair:repitair@localhost:5432/repitair
DATABASE_URL=postgresql://postgres:pEvxNiniSUzRRWjfOJWLYdkcsIWVMjEN@monorail.proxy.rlwy.net:26461/railway

# DATABASE_USER=repitair
# DATABASE_PASSWORD=repitair
# DATABASE_NAME=repitair

# Push Notifications (future)
# EXPO_ACCESS_TOKEN=

# Cloud Storage (future)
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Email (SMTP) — used for password reset codes and contact form forwarding.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=Repitair <noreply@repitair.com>

# Destination for contact-form submissions.
# SUPPORT_EMAIL=support@repitair.com

# Trust proxy — required when running behind a load balancer so req.ip
# resolves to the real client IP (otherwise per-IP rate limits break).
# Values: "1" (one proxy hop, default), "true" (trust all), or an IP/CIDR list.
# TRUST_PROXY=1

# Redis (optional — enables multi-instance token blacklist)
REDIS_URL=redis://default:njqLfzcZzpqpyWiaslPAnTVuxwvtUDcJ@monorail.proxy.rlwy.net:44236
# Spotify API (required for link parsing and OAuth)
SPOTIFY_CLIENT_ID=417531c2961d4915b57d96e0cfb2bd01
SPOTIFY_CLIENT_SECRET=bc51f6fc1339483ea8f3398c885df789
# Spotify OAuth redirect URI (set to your backend's public URL + /api/auth/spotify/callback)
SPOTIFY_REDIRECT_URI=https://repitair-api-production.up.railway.app/api/auth/spotify/callback

# Apple Music API (required for Apple Music link parsing)
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Background Removal (remove.bg)
# REMOVE_BG_API_KEY=
